systemctl --user list-unit-files | grep dunst\
\
# Disable dunst since Hyprland has built-in notifications\
systemctl --user disable --now dunst.service\
systemctl --user mask dunst.service\
\
# Kill any running dunst processes\
pkill dunst\
\
# Remove dunst autostart if it exists\
rm -f ~/.config/autostart/dunst.desktop\
rm -f ~/.config/systemd/user/dunst.service
